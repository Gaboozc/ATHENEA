{
  "name": "wirescope-mobile",
  "version": "1.0.0",
  "description": "WireScope Mobile App - Structured cabling and network project management",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "cd android && ./gradlew clean && cd ../ios && xcodebuild clean",
    "reset-cache": "npx react-native start --reset-cache",
    "pod-install": "cd ios && pod install && cd ..",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace WireScope.xcworkspace -scheme WireScope -configuration Release archive"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-community/netinfo": "^10.0.0",
    "@react-native-firebase/app": "^18.6.1",
    "@react-native-firebase/messaging": "^18.6.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^7.3.28",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "react": "18.3.1",
    "react-hook-form": "^7.47.0",
    "react-native": "0.72.6",
    "react-native-auth0": "^3.1.0",
    "react-native-biometrics": "^3.0.1",
    "react-native-camera": "^4.2.1",
    "react-native-device-info": "^10.11.0",
    "react-native-document-picker": "^9.1.1",
    "react-native-elements": "^3.4.3",
    "react-native-fs": "^2.20.0",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-image-picker": "^7.0.3",
    "react-native-keychain": "^8.1.3",
    "react-native-maps": "^1.15.0",
    "react-native-network-info": "^5.2.1",
    "react-native-paper": "^5.11.1",
    "react-native-pdf": "^6.7.3",
    "react-native-permissions": "^3.10.1",
    "react-native-print": "^0.8.0",
    "react-native-push-notification": "^8.1.1",
    "react-native-qrcode-scanner": "^1.5.5",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.27.0",
    "react-native-share": "^10.0.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-svg": "^13.14.1",
    "react-native-vector-icons": "^10.0.2",
    "react-redux": "^8.1.3",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.7.4",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.0",
    "@react-native/metro-config": "^0.72.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.0",
    "@tsconfig/react-native": "^3.0.7",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.14.200",
    "@types/node": "^24.8.1",
    "@types/react": "^18.3.26",
    "@types/react-native": "^0.72.8",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "detox": "^20.13.5",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest-setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-navigation|@react-navigation|react-native-elements|react-native-vector-icons|react-native-paper)/)"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{js,jsx,ts,tsx}"
    ]
  }
}
