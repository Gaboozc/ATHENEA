<svg width="600" height="200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#2196F3;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1976D2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Icon part -->
  <g transform="translate(80, 100)">
    <circle cx="0" cy="0" r="35" fill="url(#logoGradient)"/>
    <line x1="-55" y1="-55" x2="-35" y2="-35" stroke="#2196F3" stroke-width="8" stroke-linecap="round"/>
    <line x1="55" y1="-55" x2="35" y2="-35" stroke="#2196F3" stroke-width="8" stroke-linecap="round"/>
    <line x1="-55" y1="55" x2="-35" y2="35" stroke="#2196F3" stroke-width="8" stroke-linecap="round"/>
    <line x1="55" y1="55" x2="35" y2="35" stroke="#2196F3" stroke-width="8" stroke-linecap="round"/>
    <circle cx="-55" cy="-55" r="12" fill="#2196F3"/>
    <circle cx="55" cy="-55" r="12" fill="#2196F3"/>
    <circle cx="-55" cy="55" r="12" fill="#2196F3"/>
    <circle cx="55" cy="55" r="12" fill="#2196F3"/>
    <path d="M -12 0 L -3 9 L 18 -12" stroke="white" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  
  <!-- Text -->
  <text x="180" y="95" font-family="Arial, sans-serif" font-size="52" font-weight="bold" fill="#2C3E50">WireScope</text>
  <text x="180" y="130" font-family="Arial, sans-serif" font-size="20" fill="#7F8C8D">Cable Management System</text>
</svg>
