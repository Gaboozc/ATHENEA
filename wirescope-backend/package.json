{
  "name": "ATHENEA-backend",
  "version": "1.0.0",
  "description": "ATHENEA Backend API for tactical engineering and data network project management",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docs": "swagger-jsdoc -d swaggerDef.js src/routes/*.js -o swagger.json"
  },
  "keywords": [
    "structured-infrastructure",
    "network-management",
    "project-management",
    "api",
    "nodejs"
  ],
  "author": "ATHENEA Development Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "jsonwebtoken": "^9.0.2",
    "express-jwt": "^8.4.1",
    "jwks-rsa": "^3.1.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.11.3",
    "knex": "^3.0.1",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1481.0",
    "socket.io": "^4.7.4",
    "nodemailer": "^6.9.7",
    "firebase-admin": "^11.11.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.32.6",
    "uuid": "^9.0.1",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "dotenv": "^16.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "@types/jest": "^29.5.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ATHENEA/ATHENEA-backend.git"
  }
}