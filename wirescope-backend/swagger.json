{
  "openapi": "3.0.0",
  "info": {
    "title": "ATHENEA API",
    "version": "1.0.0",
    "description": "API for tactical engineering and data network project management",
    "contact": {
      "name": "ATHENEA Development Team",
      "email": "dev@ATHENEA.com"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Development server"
    },
    {
      "url": "https://api.ATHENEA.com/v1",
      "description": "Production server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique user identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "role": {
            "type": "string",
            "enum": ["technician", "lead_technician", "supervisor", "project_manager"],
            "description": "User role in the system"
          },
          "first_name": {
            "type": "string",
            "description": "User first name"
          },
          "last_name": {
            "type": "string", 
            "description": "User last name"
          },
          "phone": {
            "type": "string",
            "description": "User phone number"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of user skills and specialties"
          },
          "is_active": {
            "type": "boolean",
            "description": "Whether the user account is active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Account creation timestamp"
          }
        }
      },
      "Workstream": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Workstream identifier"
          },
          "org_id": {
            "type": "string",
            "format": "uuid",
            "description": "Organization identifier"
          },
          "lead_id": {
            "type": "string",
            "format": "uuid",
            "description": "Assigned lead user identifier"
          },
          "code": {
            "type": "string",
            "description": "Unique workstream code"
          },
          "label": {
            "type": "string",
            "description": "Workstream label"
          },
          "enabled": {
            "type": "boolean",
            "description": "Workstream active state"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Project identifier"
          },
          "org_id": {
            "type": "string",
            "format": "uuid",
            "description": "Organization identifier"
          },
          "workstream_id": {
            "type": "string",
            "format": "uuid",
            "description": "Parent workstream identifier"
          },
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "description": {
            "type": "string",
            "description": "Project description"
          },
          "status": {
            "type": "string",
            "description": "Project status"
          },
          "client_name": {
            "type": "string",
            "description": "Client name"
          },
          "site_address": {
            "type": "string",
            "description": "Site address"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "details": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "Additional error details"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and authorization"
    },
    {
      "name": "Users", 
      "description": "User management operations"
    },
    {
      "name": "Projects",
      "description": "Project management operations"
    },
    {
      "name": "Floor Plans",
      "description": "Floor plan management"
    },
    {
      "name": "Points",
      "description": "Network point management"
    },
    {
      "name": "Materials",
      "description": "Material and inventory management"
    },
    {
      "name": "Hardware",
      "description": "Hardware management"
    },
    {
      "name": "Notifications",
      "description": "Notification management"
    },
    {
      "name": "Reports",
      "description": "Reporting and analytics"
    }
  ]
}