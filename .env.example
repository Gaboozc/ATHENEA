# ==============================================================================
# ATHENEA ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` and fill in your actual values.
# NEVER commit `.env` to version control - it contains sensitive credentials.
#
# This file is for the Vite-powered frontend (scope/).
# For backend configuration, see wirescope-backend/.env.example
# ==============================================================================

# ------------------------------------------------------------------------------
# BASE CONFIGURATION
# ------------------------------------------------------------------------------
BASENAME=/

# ------------------------------------------------------------------------------
# GOOGLE CALENDAR OAUTH INTEGRATION
# ------------------------------------------------------------------------------
# CRITICAL: Required for Google Calendar sync functionality
#
# Setup Instructions:
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable "Google Calendar API":
#    - APIs & Services > Enable APIs & Services
#    - Search "Google Calendar API" > Enable
# 4. Create OAuth 2.0 Client ID:
#    - APIs & Services > Credentials > Create Credentials > OAuth client ID
#    - Application type: Web application
#    - Authorized JavaScript origins:
#      * http://localhost:5173 (for development)
#      * https://yourdomain.com (for production)
#    - Authorized redirect URIs:
#      * http://localhost:5173 (for development)
#      * https://yourdomain.com (for production)
# 5. Copy the "Client ID" and paste below
#
# Security Note:
# - This Client ID is public and safe to expose in frontend code
# - Never add Client Secret to frontend
# - The access token is managed locally and never sent to third parties
# - OpenClaw NLU receives ONLY the user's text prompt, NOT the token
# ------------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your_google_client_id_goes_here.apps.googleusercontent.com

# ------------------------------------------------------------------------------
# BACKEND API (OPTIONAL)
# ------------------------------------------------------------------------------
# If using the wirescope-backend for server-side features
# Leave empty if running in single-person mode (client-only)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000
VITE_API_VERSION=v1

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
# Enable/disable experimental features
# ------------------------------------------------------------------------------
VITE_ENABLE_PROACTIVE_INSIGHTS=true
VITE_ENABLE_VOICE_COMMANDS=true
VITE_ENABLE_AUTONOMOUS_EXECUTION=true
VITE_ENABLE_AUDIO_FEEDBACK=true

# ------------------------------------------------------------------------------
# OPENCLAW CONFIGURATION (FUTURE)
# ------------------------------------------------------------------------------
# If you decide to use a self-hosted OpenClaw NLU service
# Currently, intelligence module uses local keyword matching
# ------------------------------------------------------------------------------
# VITE_OPENCLAW_API_URL=https://your-openclaw-instance.com/api
# VITE_OPENCLAW_API_KEY=your_api_key_here

# ------------------------------------------------------------------------------
# ATHENEA NEURAL ACCESS (LOCALHOST TESTING)
# ------------------------------------------------------------------------------
# Optional: set these to run localhost with AI connected by default.
# If user sets values in Settings > Neural Access, localStorage takes priority.
# ------------------------------------------------------------------------------
VITE_NEURAL_PROVIDER=openai
VITE_NEURAL_API_KEY=replace_with_your_openai_or_groq_key

# ------------------------------------------------------------------------------
# ANALYTICS & MONITORING (OPTIONAL)
# ------------------------------------------------------------------------------
# For production tracking (Mixpanel, Google Analytics, Sentry, etc.)
# ------------------------------------------------------------------------------
# VITE_ANALYTICS_ID=your_analytics_id
# VITE_SENTRY_DSN=your_sentry_dsn

# ------------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# ------------------------------------------------------------------------------
VITE_DEBUG_MODE=false
VITE_SHOW_DEV_TOOLS=false

# ==============================================================================
# QUICK START CHECKLIST
# ==============================================================================
# [✓] Copy this file to `.env`
# [ ] Set VITE_GOOGLE_CLIENT_ID (required for calendar sync)
# [ ] Set VITE_API_BASE_URL (if using backend)
# [ ] Run: npm run dev
# [ ] Test: Voice command "set reminder for tomorrow at 7am"
# [ ] Verify: Should auto-execute with success earcon (ding sound)
# ==============================================================================
