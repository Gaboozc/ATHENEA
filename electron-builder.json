{
  "appId": "com.athenea.terminal",
  "productName": "ATHENEA",
  "copyright": "Copyright © 2025 ATHENEA",
  "files": [
    "dist/**/*",
  "electron-main.cjs",
    "electron-preload.js"
  ],
  "directories": {
    "buildResources": "src/assets/img"
  },
  "win": {
    "target": "nsis",
  "icon": "src/assets/img/logo.ico"
