<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wdfRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_dark">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wdfTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎯 Focus Mode"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wdfStreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="racha: 0 🔥"
            android:textColor="#f59e0b"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Current task -->
    <TextView
        android:id="@+id/wdfTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Sin tarea activa"
        android:textColor="#9aa3ad"
        android:textSize="12sp" />

    <!-- Timer row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wdfTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏱ 25:00"
            android:textColor="#9aa3ad"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wdfPlayPause"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/widget_btn_cyan"
            android:text="▶ Iniciar"
            android:textColor="#1a1a2e"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
