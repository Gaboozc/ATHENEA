<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wfsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_dark">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wfsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💰 Finanzas"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wfsAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponible: 0%"
            android:textColor="#22c55e"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/wfsProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#1ec9ff"
        android:progressBackgroundTint="#2d3748" />

    <!-- Amounts row -->
    <TextView
        android:id="@+id/wfsAmounts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="$0 / $0"
        android:textColor="#9aa3ad"
        android:textSize="11sp" />

    <!-- Last expense + log button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wfsLastExpense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Último: —"
            android:textColor="#9aa3ad"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/wfsLogBtn"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/widget_btn_cyan"
            android:text="+ Registrar"
            android:textColor="#1a1a2e"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
