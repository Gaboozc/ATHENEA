<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/whtRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/whtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✅ Rutinas hoy"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/whtProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0 ✓"
            android:textColor="#22c55e"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Routine 1 -->
    <LinearLayout
        android:id="@+id/whtRoutine1Row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/whtRoutine1Check"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="○"
            android:textColor="#9aa3ad"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/whtRoutine1Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""
            android:textColor="#e2e8f0"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Routine 2 -->
    <LinearLayout
        android:id="@+id/whtRoutine2Row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/whtRoutine2Check"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="○"
            android:textColor="#9aa3ad"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/whtRoutine2Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""
            android:textColor="#e2e8f0"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Routine 3 -->
    <LinearLayout
        android:id="@+id/whtRoutine3Row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/whtRoutine3Check"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="○"
            android:textColor="#9aa3ad"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/whtRoutine3Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""
            android:textColor="#e2e8f0"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/whtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Sin rutinas para hoy"
        android:textColor="#9aa3ad"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
