<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wifRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_dark">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wifTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧠 Intelligence"
            android:textColor="#e2e8f0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wifSeverityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/widget_btn_muted"
            android:text="INFO"
            android:textColor="#e2e8f0"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Insight text -->
    <TextView
        android:id="@+id/wifInsightText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="No hay insights recientes"
        android:textColor="#e2e8f0"
        android:textSize="12sp" />

    <!-- Footer row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wifTimestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textColor="#9aa3ad"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/wifViewBtn"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/widget_btn_muted"
            android:text="Ver →"
            android:textColor="#1ec9ff"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
